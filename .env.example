# Environment Variables
# Copy this to .env and fill in your values

# MongoDB connection string
MONGODB_URI=mongodb://localhost:27017/veshtit

# JWT Secret (use a long random string)
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# AES-256-GCM Encryption Key (must be exactly 64 hex chars = 32 bytes)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
AES_ENCRYPTION_KEY=your-64-character-hex-encryption-key-here-change-this

# Admin credentials (used to seed the first user)
APP_USERNAME=admin
APP_PASSWORD=changeme123

# Backend URL (used by frontend to make API calls)
BACKEND_URL=http://localhost:3001

# Backend port
PORT=3001

# Frontend port
FRONTEND_PORT=3000
